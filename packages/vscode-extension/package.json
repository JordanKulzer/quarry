{
  "name": "quarry-vscode",
  "displayName": "Quarry",
  "description": "Add multiple search terms, find every file containing all of them, and jump straight to the matching lines.",
  "version": "0.2.3",
  "publisher": "jordankulzer",
  "categories": [
    "Other"
  ],
  "keywords": [
    "search",
    "multi-term",
    "find",
    "multi search",
    "code search"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/JordanKulzer/quarry"
  },
  "homepage": "https://github.com/JordanKulzer/quarry",
  "bugs": {
    "url": "https://github.com/JordanKulzer/quarry/issues"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "main": "./dist/extension.js",
  "icon": "media/icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "quarry-sidebar",
          "title": "Quarry",
          "icon": "media/quarry-icon.svg"
        }
      ]
    },
    "views": {
      "quarry-sidebar": [
        {
          "type": "webview",
          "id": "quarry.searchPanel",
          "name": "Search"
        }
      ]
    },
    "commands": [
      {
        "command": "quarry.openMenu",
        "title": "Quarry Options",
        "icon": "$(ellipsis)"
      },
      {
        "command": "quarry.focus",
        "title": "Quarry: Focus Search Panel"
      }
    ],
    "keybindings": [
      {
        "command": "quarry.focus",
        "key": "ctrl+shift+f10",
        "mac": "cmd+shift+f10"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "quarry.openMenu",
          "when": "view == quarry.searchPanel",
          "group": "navigation"
        }
      ]
    }
  },
  "dependencies": {
    "@quarry/core": "*",
    "@vscode/ripgrep": "^1.15.0"
  },
  "devDependencies": {
    "@types/node": "^18.19.130",
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.4.0"
  },
  "scripts": {
    "compile": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node --watch",
    "vscode:prepublish": "npm run compile"
  }
}
